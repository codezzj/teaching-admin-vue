# ============================================================
# .dockerignore — 构建时排除的文件，减小构建上下文体积
# ============================================================

# ---------- 依赖 ----------
node_modules

# ---------- 构建产物 ----------
dist
.vite
.cache
*.tsbuildinfo

# ---------- Mock 数据（仅开发环境使用，生产构建时不需要） ----------
mock

# ---------- IDE ----------
.idea
.vscode
*.swp
*.swo

# ---------- 操作系统文件 ----------
.DS_Store
Thumbs.db

# ---------- Git ----------
.git
.gitignore
.gitattributes
.github

# ---------- 环境变量 ----------
.env
.env.local
.env.*.local

# ---------- 文档与脚本 ----------
README.md
*.md
deploy.sh

# ---------- Docker 自身文件 ----------
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.override.yml
