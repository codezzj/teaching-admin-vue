# ============================================================
# .dockerignore — 构建时排除的文件，减小构建上下文体积
# ============================================================

# ---------- 依赖 ----------
node_modules

# ---------- 构建产物（每次重新 build 时不需要复制旧的 dist） ----------
dist
.vite
.cache

# ---------- Mock 数据（仅开发环境使用，生产构建不需要） ----------
mock

# ---------- IDE ----------
.idea
.vscode
*.swp
*.swo

# ---------- 操作系统文件 ----------
.DS_Store
Thumbs.db

# ---------- Git ----------
.git
.gitignore
.gitattributes

# ---------- 环境变量（敏感信息不应打入镜像） ----------
.env
.env.local
.env.*.local

# ---------- Docker 自身文件 ----------
docker-compose.override.yml
